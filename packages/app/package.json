{
  "name": "@i3x/app",
  "version": "0.1.0",
  "description": "i3X application — composition root that wires all packages together",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@i3x/core": "*",
    "@i3x/opcua-connector": "*",
    "@i3x/rest-server": "*",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "tsx": "^4.16.0"
  }
}
