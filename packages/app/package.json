{
  "name": "@node-i3x/app",
  "version": "0.2.3",
  "description": "i3X CLI -- expose OPC UA servers as i3X REST APIs",
  "license": "AGPL-3.0-or-later OR LicenseRef-Sterfive-Commercial",
  "author": "Sterfive SAS <contact@sterfive.com> (https://sterfive.com)",
  "homepage": "https://sterfive.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-opcua/node-i3x.git",
    "directory": "packages/app"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "i3x": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "i3x.config.example.yml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-i3x/core": "0.2.3",
    "@node-i3x/opcua-connector": "0.2.3",
    "@node-i3x/rest-server": "0.2.3",
    "commander": "^13.0.0",
    "cosmiconfig": "^9.0.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^11.0.0",
    "fastify-plugin": "^5.0.0",
    "js-yaml": "^4.1.0",
    "node-opcua": "^2.128.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0"
  }
}
