  "license": "AGPL-3.0-or-later OR LicenseRef-Sterfive-Commercial",
  "author": "Sterfive SAS <contact@sterfive.com> (https://sterfive.com)",
  "homepage": "https://sterfive.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-opcua/node-i3x.git",
    "directory": "packages/demo-embedded"
  },
  "description": "End-to-end demo: OPC UA server + i3X REST API wired via PseudoSession",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "i3x-demo": "./dist/index.js",
    "i3x-demo-client": "./dist/client.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "LICENSE-AGPL-3.0",
    "LICENSING.md"
  ],
  "scripts": {
    "build": "tsup",
    "start": "npx tsx src/index.ts",
    "demo": "npx tsx src/index.ts",
    "demo:remote": "npx tsx src/demo-remote.ts",
    "client": "npx tsx src/client.ts"
  },
  "dependencies": {
    "@node-i3x/core": "0.4.0",
    "@node-i3x/opcua-connector": "0.4.0",
    "@node-i3x/pseudo-session-connector": "0.4.0",
    "@node-i3x/rest-server": "0.4.0",
    "fastify": "^5.8.5",
    "@fastify/cors": "^11.2.0",
    "fastify-plugin": "^6.0.0",
    "node-opcua": "^2.173.1"
