# -- OPC UA Connection --
NODE_I3X_OPCUA_ENDPOINT=opc.tcp://localhost:4840
NODE_I3X_OPCUA_SECURITY_MODE=None

# -- Model --
NODE_I3X_PRELOAD=true
NODE_I3X_PRELOAD_STRICT=false

# -- Subscriptions --
NODE_I3X_PUBLISH_INTERVAL=5

# -- Server --
NODE_I3X_PORT=8000
NODE_I3X_HOST=127.0.0.1
NODE_I3X_LOG_LEVEL=info

# -- Development --

# -- Optimized Client --
# auto = detect and use if installed, disabled = skip
NODE_I3X_OPCUA_OPTIMIZED_CLIENT=auto
