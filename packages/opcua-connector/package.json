{
  "name": "@node-i3x/opcua-connector",
  "version": "0.1.0",
  "description": "i3X OPC UA adapter — implements IDataSourcePort using node-opcua",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-i3x/core": "*",
    "node-opcua": "^2.128.0",
    "node-opcua-client": "^2.128.0"
  },
  "optionalDependencies": {
    "@sterfive/opcua-optimized-client": "*"
  }
}
